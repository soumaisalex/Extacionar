# ==========================================
# Variáveis de Ambiente - Extacionar
# ==========================================
# Crie uma cópia deste arquivo com o nome .env.local 
# e insira as suas credenciais reais. Não comite o .env.local!

# Conexão com o Banco de Dados (Neon.tech Serverless Postgres)
# Formato esperado: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://usuario_falso:senha_falsa@ep-nome-do-banco.us-east-2.aws.neon.tech/extacionar_db?sslmode=require"

# Chave Secreta para assinatura dos tokens JWT (Login)
# Em produção, gere uma string longa e aleatória
JWT_SECRET="sua_chave_secreta_super_segura_aqui"
